# =============================================================================
# Chat IA — Sistema hoja del ecosistema SaaS multi-tenant
# Copiar a .env y completar los valores
# =============================================================================

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/chatia_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Groq (LLM) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Ecosistema SaaS ────────────────────────────────────────────────────────────
# URL del owner-dashboard (source of truth para auth, orgs y permisos)
DASHBOARD_URL=http://localhost:3001

# ── Firebase Admin (MISMO proyecto que el owner-dashboard) ────────────────────
# Dejar vacíos para arrancar en modo dev sin auth real
# Obtener desde: Firebase Console → Proyecto → Configuración → Cuentas de servicio
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Nota: los \n en la private key deben ser literales \\n en el .env
FIREBASE_PRIVATE_KEY=

# ── Webhooks de canales (Meta / TikTok) ───────────────────────────────────────
META_APP_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos (coma-separados). Vacío = permitir todos (solo dev)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
