      [ChannelType.WHATSAPP, this.whatsapp],
      [ChannelType.INSTAGRAM, this.instagram],
      [ChannelType.MESSENGER, this.messenger],
      [ChannelType.TIKTOK, this.tiktok],
    ]);
  }

  get(type: ChannelType): IChannel {
